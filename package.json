{
  "name": "tara-finance-agent",
  "version": "1.0.0",
  "description": "Tara — personal finance research agent (Provue take-home)",
  "main": "index.js",
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "start":  "tsx src/server.ts",
    "dev":    "tsx --watch src/server.ts",
    "ingest": "tsx scripts/ingest.ts",
    "evals":  "tsx evals/run-evals.ts",
    "build":  "tsc --noEmit"
  },
  "dependencies": {
    "@ai-sdk/groq":    "^1.0.0",
    "@mastra/core":    "^1.0.0",
    "dotenv":          "^16.0.0",
    "express":         "^5.0.0",
    "pg":              "^8.0.0",
    "zod":             "^3.23.8"
  },
  "devDependencies": {
    "@types/express":  "^5.0.0",
    "@types/node":     "^22.0.0",
    "@types/pg":       "^8.0.0",
    "tsx":             "^4.0.0",
    "typescript":      "^5.0.0"
  }
}